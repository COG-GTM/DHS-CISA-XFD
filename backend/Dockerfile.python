# Dockerfile for FastAPI application
FROM python:3.11-slim

WORKDIR /app

# Upgrade pip tools
RUN pip install --upgrade pip setuptools wheel

# Copy base and worker requirements
COPY requirements.txt .

# 👇 Copy the local patched pshtt package before install
COPY external/pshtt external/pshtt

# Install base and worker requirements
RUN pip install --no-cache-dir -r requirements.txt

# Copy FastAPI application code
COPY src/xfd_django .

# Copy lint config (optional)
COPY .pylintrc .

# Set Django settings environment variable
ENV DJANGO_SETTINGS_MODULE=xfd_django.settings

# Launch app
CMD ["uvicorn", "--workers", "4", "xfd_django.asgi:app", "--host", "0.0.0.0", "--port", "3000", "--reload"]
